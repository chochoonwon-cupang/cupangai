# Supabase (서버 API에서만 사용 — 클라이언트에 노출되지 않음)
# config.py와 동일한 값 사용 (메인 프로그램 로그인과 연동)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 또는: SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase 클라이언트 (브라우저에서 사용, NEXT_PUBLIC_ 접두사로 노출됨)
NEXT_PUBLIC_SUPABASE_URL=너의_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=너의_anon_key
